# ──────────────────────────────────────────────
# Brookhaven Property Pipeline — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.sample .env
#   source .env
# ──────────────────────────────────────────────

# PostgreSQL connection string (required)
export DATABASE_URL=postgresql://postgres:postgres@localhost:5432/brookhaven

# Optional geocoder API key (not currently used — Census geocoder needs no key)
export GEOCODER_API_KEY=

# ──────────────────────────────────────────────
# MLS / IDX — RESO Web API (OneKey MLS)
# Only needed if you have a NY real estate license or licensed broker sponsorship.
# Leave blank to skip the mls_reso source entirely.
# ──────────────────────────────────────────────

# Base RESO Web API URL provided by your MLS or IDX vendor
export MLS_API_URL=

# OAuth 2.0 client credentials (preferred auth method)
export MLS_TOKEN_URL=
export MLS_CLIENT_ID=
export MLS_CLIENT_SECRET=

# Static bearer token — use this OR the OAuth vars above, not both
export MLS_ACCESS_TOKEN=
